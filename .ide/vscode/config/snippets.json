  "CMK Check Plugin": {
    "scope": "python",
    "prefix": "cmk-check-plugin",
    "description": "Checkmk agent-based check plugin boilerplate",
    "body": [
      "#!/usr/bin/env python3",
      "# Copyright (C) ${CURRENT_YEAR} Checkmk GmbH - License: GNU General Public License v2",
      "# This file is part of Checkmk (https://checkmk.com). It is subject to the terms and",
      "# conditions defined in the file COPYING, which is part of this source code package.",
      "",
      "from collections.abc import Mapping",
      "from typing import Any",
      "",
      "from cmk.agent_based.v2 import (",
      "    CheckPlugin,",
      "    CheckResult,",
      "    DiscoveryResult,",
      "    Result,",
      "    Service,",
      "    State,",
      ")",
      "",
      "",
      "def discover_${1:plugin_name}(section: ${2:Section}) -> DiscoveryResult:",
      "    yield Service()",
      "",
      "",
      "def check_${1:plugin_name}(",
      "    params: Mapping[str, Any],",
      "    section: ${2:Section},",
      ") -> CheckResult:",
      "    yield Result(state=State.OK, summary=\"${3:All good}\")",
      "",
      "",
      "check_plugin_${1:plugin_name} = CheckPlugin(",
      "    name=\"${1:plugin_name}\",",
      "    service_name=\"${4:Service Name}\",",
      "    discovery_function=discover_${1:plugin_name},",
      "    check_function=check_${1:plugin_name},",
      "    check_ruleset_name=\"${1:plugin_name}\",",
      "    check_default_parameters={},",
      ")",
      ""
    ]
  },
  "CMK Agent Section": {
    "scope": "python",
    "prefix": "cmk-agent-section",
    "description": "Checkmk agent section definition",
    "body": [
      "#!/usr/bin/env python3",
      "# Copyright (C) ${CURRENT_YEAR} Checkmk GmbH - License: GNU General Public License v2",
      "# This file is part of Checkmk (https://checkmk.com). It is subject to the terms and",
      "# conditions defined in the file COPYING, which is part of this source code package.",
      "",
      "from cmk.agent_based.v2 import (",
      "    AgentSection,",
      "    StringTable,",
      ")",
      "",
      "",
      "def parse_${1:section_name}(string_table: StringTable) -> ${2:Section} | None:",
      "    if not string_table:",
      "        return None",
      "    return ${2:Section}(${3:})",
      "",
      "",
      "agent_section_${1:section_name} = AgentSection(",
      "    name=\"${1:section_name}\",",
      "    parse_function=parse_${1:section_name},",
      ")",
      ""
    ]
  },
  "CMK Check Parameters (Form Spec)": {
    "scope": "python",
    "prefix": "cmk-form-spec",
    "description": "Checkmk check parameter form spec (v1 rulesets)",
    "body": [
      "#!/usr/bin/env python3",
      "# Copyright (C) ${CURRENT_YEAR} Checkmk GmbH - License: GNU General Public License v2",
      "# This file is part of Checkmk (https://checkmk.com). It is subject to the terms and",
      "# conditions defined in the file COPYING, which is part of this source code package.",
      "",
      "from cmk.rulesets.v1 import Help, Label, Message, Title",
      "from cmk.rulesets.v1.form_specs import (",
      "    DictElement,",
      "    Dictionary,",
      "    InputHint,",
      "    LevelDirection,",
      "    Levels,",
      "    SimpleLevels,",
      ")",
      "from cmk.rulesets.v1.rule_specs import CheckParameters, HostAndItemCondition, Topic",
      "",
      "",
      "def _parameter_form() -> Dictionary:",
      "    return Dictionary(",
      "        title=Title(\"${1:Parameter Title}\"),",
      "        elements={",
      "            \"${2:param_key}\": DictElement(",
      "                parameter_form=SimpleLevels(",
      "                    title=Title(\"${3:Level Title}\"),",
      "                    level_direction=LevelDirection.UPPER,",
      "                    form_spec_template=Levels(",
      "                        form_spec_template=InputHint(value=0.0),",
      "                    ),",
      "                    prefill_fixed_levels=InputHint(value=(0.0, 0.0)),",
      "                ),",
      "            ),",
      "        },",
      "    )",
      "",
      "",
      "rule_spec_${4:rule_name} = CheckParameters(",
      "    name=\"${4:rule_name}\",",
      "    title=Title(\"${1:Parameter Title}\"),",
      "    topic=Topic.${5:GENERAL},",
      "    parameter_form=_parameter_form,",
      "    condition=HostAndItemCondition(item_title=Title(\"${6:Item}\")),",
      ")",
      ""
    ]
  },
  "CMK Special Agent": {
    "scope": "python",
    "prefix": "cmk-special-agent",
    "description": "Checkmk special agent boilerplate",
    "body": [
      "#!/usr/bin/env python3",
      "# Copyright (C) ${CURRENT_YEAR} Checkmk GmbH - License: GNU General Public License v2",
      "# This file is part of Checkmk (https://checkmk.com). It is subject to the terms and",
      "# conditions defined in the file COPYING, which is part of this source code package.",
      "",
      "from collections.abc import Iterator, Sequence",
      "",
      "from cmk.agent_based.v2 import (",
      "    SpecialAgentSection,",
      "    StringTable,",
      ")",
      "from cmk.special_agents.v0_unstable.agent_common import (",
      "    SectionWriter,",
      "    special_agent_main,",
      ")",
      "from cmk.special_agents.v0_unstable.argument_parsing import (",
      "    Args,",
      "    create_default_argument_parser,",
      ")",
      "",
      "",
      "def parse_arguments(argv: Sequence[str] | None) -> Args:",
      "    parser = create_default_argument_parser(description=\"${1:Agent description}\")",
      "    parser.add_argument(\"--host\", required=True)",
      "    return parser.parse_args(argv)",
      "",
      "",
      "def agent_${2:agent_name}(args: Args) -> Iterator[str]:",
      "    with SectionWriter(\"${2:agent_name}\") as writer:",
      "        writer.append(\"${3:output}\")",
      "",
      "",
      "def main() -> None:",
      "    special_agent_main(parse_arguments, agent_${2:agent_name})",
      ""
    ]
  },
  "CMK Graphing Metric": {
    "scope": "python",
    "prefix": "cmk-metric",
    "description": "Checkmk graphing metric definition",
    "body": [
      "#!/usr/bin/env python3",
      "# Copyright (C) ${CURRENT_YEAR} Checkmk GmbH - License: GNU General Public License v2",
      "# This file is part of Checkmk (https://checkmk.com). It is subject to the terms and",
      "# conditions defined in the file COPYING, which is part of this source code package.",
      "",
      "from cmk.graphing.v1 import Color, Metric, Title, Unit",
      "",
      "",
      "metric_${1:metric_name} = Metric(",
      "    name=\"${1:metric_name}\",",
      "    title=Title(\"${2:Metric Title}\"),",
      "    unit=Unit.${3:COUNT},",
      "    color=Color.${4:BLUE},",
      ")",
      ""
    ]
  }
}
