set -e

# shellcheck source=.pre-commit-scripts/lib-precommit
source "$(dirname "$0")/lib-precommit"

# Filter out files that break doctest collection:
# - tests/*: test files are not doctest targets
# - non-free/packages/*: isolated package trees whose import paths cannot be
#   resolved by pytest running from the repo root
# - omd/packages/*: same as non-free/packages
# - __main__.py: collides with pytest's own __main__ module during collection
declare -a FILES

for param in "$@"; do
    if [[ "$param" == tests* || "$param" == non-free/packages/* || "$param" == omd/packages/* || "$param" == */__main__.py ]]; then
        continue
    fi
    # the enterprise/... files are included via symlinks. The doctests do not work reliably
    # when running out of the enterprise directory. So redirect to the symlink location.
    FILES+=("$(readlink -f "$param" | sed -e "s|/enterprise/|/|g;s|/cloud/|/|g;s|/managed/|/|g")")
done

NUM_PARAM=${#FILES[@]}

if [ "$NUM_PARAM" == "0" ]; then
    echo No files to check. >&2
    exit 0
fi

REPO_PATH="$(git rev-parse --show-toplevel)"
UVENV="$REPO_PATH/scripts/run-uvenv"

pushd "$REPO_PATH" >/dev/null

# --doctest-ignore-import-errors: skip modules that fail to import (e.g.
#   namespace packages with relative imports that pytest can't resolve)
$UVENV python -m pytest --doctest-modules --doctest-ignore-import-errors "${FILES[@]}" || (
    EXIT=$?
    if test $EXIT -eq 5 || test $EXIT -eq 4; then
        # This means no tests have been found.
        exit 0
    elif test $EXIT -eq 2; then
        # Collection errors from modules that cannot be imported (e.g.
        # namespace sub-packages with relative imports). These are
        # harmless — the modules simply don't contain collectable doctests.
        exit 0
    else
        exit $EXIT
    fi
)
popd >/dev/null
