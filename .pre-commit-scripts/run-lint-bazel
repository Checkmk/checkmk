# This file is for execution by the pre-commit framework.
# Maps changed file paths to their Bazel packages and runs bazel lint on those packages.
set -e

# shellcheck source=.pre-commit-scripts/lib-precommit
source "$(dirname "$0")/lib-precommit"

declare -a PACKAGES
declare -a CHANGED_FILES

for param in "$@"; do
    PACKAGES+=("$(find_bazel_package "$param")")
    CHANGED_FILES+=("$param")
done

if [ "${#PACKAGES[@]}" == "0" ]; then
    echo "No packages to lint." >&2
    exit 0
fi

# Deduplicate
mapfile -t PACKAGES < <(printf '%s\n' "${PACKAGES[@]}" | sort -u)

pushd "${GIT_ROOT}" >/dev/null
bazel lint -- "${PACKAGES[@]}"

# Apply auto-fix patches generated by linters (e.g. ruff isort).
# bazel lint in fix mode produces patches in the sandbox but does not apply
# them to the working tree.  We collect and apply them here so that
# pre-commit can re-stage the fixed files.
# Only apply fixes for files that are part of this commit (--include), so
# pre-existing issues in other files of the same package are left alone.
include_args=()
for f in "${CHANGED_FILES[@]}"; do
    include_args+=("--include=$f")
done

applied=0
while IFS= read -r -d '' patch; do
    [ -s "$patch" ] || continue
    if git apply --check "${include_args[@]}" "$patch" 2>/dev/null; then
        git apply "${include_args[@]}" "$patch"
        applied=1
    fi
done < <(find -L bazel-out -name '*.AspectRulesLintRuff.patch' -print0 2>/dev/null)
popd >/dev/null

if [ "$applied" -eq 1 ]; then
    echo "Lint fixes applied — please review and re-commit." >&2
    exit 1
fi
