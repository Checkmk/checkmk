load("@@//bazel/rules:dependency_info.bzl", "dependency_info")

package(default_package_metadata = [":dependency_info"])

dependency_info(
    name = "dependency_info",
    package_name = "cpp-httplib",
    cpe_format_str = "cpe:2.3:a:cpp-httplib_project:cpp-httplib:%s:*:*:*:*:*:*:*",
    license_kind = "@package_metadata//licenses/spdx:MIT",
    license_text = "LICENSE",
    purl_namespace = "yhirose",
    purl_type = "github",
    version = module_version(),
)

cc_library(
    name = "httplib",
    hdrs = ["httplib.h"],
    copts = [
        "-DCPPHTTPLIB_OPENSSL_SUPPORT",
        "-DCPPHTTPLIB_ZLIB_SUPPORT",
    ],
    features = [
        "parse_headers",
    ],
    includes = ["."],
    visibility = ["//visibility:public"],
    deps = [
        # "@openssl",  # req. CMK-25756
        "@zlib",
    ],
)

alias(
    name = "cpp-httplib",
    actual = ":httplib",
    visibility = ["//visibility:public"],
)
