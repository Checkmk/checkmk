load("@rules_foreign_cc//foreign_cc:defs.bzl", "configure_make")

filegroup(
    name = "srcs",
    srcs = glob(
        ["**/*"],
    ),
    tags = ["manual"],
)

configure_make(
    name = "libgsf",
    # Pass DESTDIR to make so `make install` writes into a throwaway staging
    # directory inside $INSTALLDIR rather than to the literal /usr/share paths
    # baked into the binaries via configure_options below. libgsf installs 46
    # gettext catalogues to $(localedir) and a gsf-office.thumbnailer DATA file
    # to $(datadir)/thumbnailers; with the absolute --datadir/--localedir those
    # would target the read-only system tree (it only "succeeds" on build hosts
    # whose /usr is writable, e.g. CI containers as root -- under the local
    # linux-sandbox /usr is read-only and the install fails). The baked paths
    # still appear in the binaries' .rodata -- that is the whole point of the
    # relocatable-binary scheme (SUP-28810) -- but the actual install layout is
    # controlled here and the bits we want are relocated into the bin/lib/
    # include/share layout by postfix_script before the staging tree is deleted.
    args = [
        "-j4",
        "DESTDIR=$$INSTALLDIR$$/staging",
    ],
    configure_options = [
        # Bake a stable GSFLOCALEDIR into the binaries instead of the per-build
        # $BUILD_TMPDIR path. libgsf computes GSFLOCALEDIR two different ways:
        # libgsf-1.so uses $(datadir)/locale (i.e. $(prefix)/share/locale) and
        # the gsf tools use $(localedir) directly. Both must be set to avoid
        # leaking the bazel sandbox path into .rodata (SUP-28810).
        # --prefix=/usr likewise keeps libdir (== the rpath libtool bakes into
        # the binaries) at the stable /usr/lib rather than the sandbox path.
        # /usr/share is used rather than an OMD placeholder because the libgsf
        # packaging does not patch the compiled-in path at install time;
        # gettext gracefully falls back to English if no gsf catalogue is found.
        "--prefix=/usr",
        "--datadir=/usr/share",
        "--localedir=/usr/share/locale",
    ],
    copts = [
        "-Wno-error=incompatible-pointer-types",
    ],
    env = {
        "PKG_CONFIG_PATH": ":".join([
            "/usr/lib/pkgconfig",
            "/usr/lib64/pkgconfig",
            "/usr/lib/x86_64-linux-gnu/pkgconfig",
        ]),
    },
    lib_source = ":srcs",
    out_binaries = [
        "gsf",
        "gsf-office-thumbnailer",
        "gsf-vba-dump",
    ],
    out_data_dirs = [
        "share",
    ],
    out_data_files = [
        "lib/libgsf-1.la",
        "lib/pkgconfig/libgsf-1.pc",
    ],
    out_shared_libs = [
        "libgsf-1.so",
        "libgsf-1.so.114",
        "libgsf-1.so.114.0.44",
    ],
    out_static_libs = [
        "libgsf-1.a",
    ],
    postfix_script = """
        set -ex
        # `make install DESTDIR=...` (see args) laid everything out under the
        # baked-in FHS prefix at <staging>/usr/{bin,lib,include,share}. Because
        # --datadir/--localedir are absolute, the gettext catalogues and the
        # gsf-office.thumbnailer DATA file landed in <staging>/usr/share instead
        # of the read-only system tree. Relocate the bits we expose (out_binaries,
        # out_shared_libs, out_static_libs, out_data_dirs, out_data_files) into
        # the bin/lib/include/share layout rules_foreign_cc expects. The
        # /usr/{lib,share} paths inside the binaries are unaffected -- that is
        # deliberate and load-bearing for the relocatable-binary scheme (see
        # configure_options).
        STAGE=$${INSTALLDIR}/staging
        mkdir -p $${INSTALLDIR}/bin $${INSTALLDIR}/lib $${INSTALLDIR}/include $${INSTALLDIR}/share
        cp -a $${STAGE}/usr/bin/. $${INSTALLDIR}/bin/
        cp -a $${STAGE}/usr/lib/. $${INSTALLDIR}/lib/
        cp -a $${STAGE}/usr/include/. $${INSTALLDIR}/include/
        cp -a $${STAGE}/usr/share/. $${INSTALLDIR}/share/
        rm -rf $${STAGE}
    """,
    set_file_prefix_map = True,
    tags = ["manual"],
    targets = ["install"],
    visibility = ["//visibility:public"],
)
