load("@@//bazel/rules:dependency_info.bzl", "dependency_info")
load("@rules_foreign_cc//foreign_cc:defs.bzl", "configure_make")

package(default_package_metadata = [":dependency_info"])

dependency_info(
    name = "dependency_info",
    package_name = "openssl",
    cpe_format_str = "cpe:2.3:a:openssl:openssl:%s:*:*:*:*:*:*:*",
    license_kind = "@package_metadata//licenses/spdx:OpenSSL",
    license_text = "LICENSE.txt",
    purl_namespace = "openssl",
    purl_type = "github",
    version = module_version(),
)

filegroup(
    name = "all_srcs",
    srcs = glob(["**"]),
)

configure_make(
    name = "openssl",
    args = ["-j6"],
    configure_command = "config",
    configure_in_place = True,
    configure_options = [
        # In order to relocate OpenSSL after the Bazel build to a configurable
        # directory (e.g. /omd/versions/2.3.0p23-cee/skel/etc/ssl/) we have to
        # binary search/replace the compiled-in path.
        # Note that openssldir can't be absolute since the provided directory would
        # have to be writeable at build time. Left relative it will be prefixed
        # to an also absolute path provided by foreign_cc's `configure_make`
        "--openssldir='skel/etc/ssl'",
        "--libdir=lib",
        "enable-md2",
        "no-module",
        "no-tests",
        "-O2",
    ],
    copts = ["-Wl,--rpath,$ORIGIN_VAR/../lib"],
    # This is a nasty workaround for Bazel's inability to escape `$ORIGIN`
    # combined with foreign_cc/configure_make's RPATH agnosticness
    #   see https://github.com/bazelbuild/rules_foreign_cc/issues/940
    # There is a caveat left, though: this rule will append "/opt/gcc-14.2.0/lib/../lib64"
    #   + the actual build directory, leading to a potentially wrong RPATH
    #   next to the fact that build artifacts won't be binary identical even
    #   when built in an exact same environment
    # This can be worked around by setting RPATH again after `bazel build` still
    # leaving us with RPATH placeholders of different size
    # Unfortunately this does not work for dynamic libraries, since strangely
    # for those the flags definded with `copts` will be appended rather than
    # prepended, resulting in wrong RPATH components in front of `$ORIGIN/../lib`
    # For that reason we need to manually set RPATH outside Bazel (during `make`)
    env = {"ORIGIN_VAR": "\\\\$$\\$$ORIGIN"},
    lib_name = "openssl",
    lib_source = ":all_srcs",
    out_binaries = [
        "openssl",
        "c_rehash",
    ],
    out_data_dirs = [
        "skel",
        "lib/pkgconfig",
        "lib/engines-3",
    ],
    out_shared_libs = [
        # Note that for Linux builds, libssl must come before libcrypto on the
        # linker command-line. As such, libssl must be listed before libcrypto.
        "libssl.so",
        "libssl.so.3",
        "libcrypto.so",
        "libcrypto.so.3",
    ],
    set_file_prefix_map = True,
    targets = [
        "build_programs",
        "install_sw",
        "install_ssldirs",
    ],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "gen_dir",
    srcs = [":openssl"],
    output_group = "gen_dir",
    visibility = ["//visibility:public"],
)

configure_make(
    name = "openssl_static",
    # Pass DESTDIR to make so `make install_dev` writes into a
    # throwaway staging directory inside $INSTALLDIR rather than to
    # the literal absolute paths (--prefix=/usr, --libdir=/usr/lib,
    # --openssldir=/etc/ssl) we bake into the libraries via
    # configure_options below.  The baked paths still appear in
    # libcrypto.a's .rodata as OPENSSLDIR/ENGINESDIR/MODULESDIR --
    # that is the whole point: consumers that statically link
    # libcrypto.a (e.g. monitoring-plugins/check_dhcp,
    # monitoring-plugins/check_icmp) inherit those strings, and we
    # need them to be deterministic FHS paths rather than per-build
    # bazel sandbox paths.  postfix_script then relocates the .a
    # files and headers from the staging tree into the lib/include
    # layout rules_foreign_cc expects.
    args = [
        "-j6",
        "DESTDIR=$$INSTALLDIR$$/staging",
    ],
    configure_command = "Configure",
    configure_in_place = True,
    configure_options = [
        # See the args note above: these absolute paths bake stable
        # OPENSSLDIR/LIBDIR/ENGINESDIR/MODULESDIR strings into
        # libcrypto.a so the bazel sandbox path does not leak into
        # binaries that statically link this archive.  The strings
        # are dead under correct operation -- the only consumers of
        # this static archive (monitoring-plugins root plugins,
        # Rust openssl-sys for host_crates) do not load openssl
        # config files and do not dlopen engines or providers.
        "--prefix=/usr",
        "--libdir=/usr/lib",
        "--openssldir=/etc/ssl",
        "no-comp",
        "no-idea",
        "no-module",
        "no-shared",
        "no-static-engine",
        "no-tests",
        "no-weak-ssl-ciphers",
        "-fPIC",
        # Match the shared openssl target's optimization level.
        "-O2",
    ] + select({
        "@platforms//cpu:aarch64": ["linux-aarch64"],
        "//conditions:default": [],
    }),
    lib_name = "openssl_static",
    lib_source = ":all_srcs",
    out_lib_dir = "lib",
    out_static_libs = [
        "libssl.a",
        "libcrypto.a",
    ],
    postfix_script = """
        set -e
        mkdir -p $${INSTALLDIR}/lib $${INSTALLDIR}/include
        cp -P $${INSTALLDIR}/staging/usr/lib/libcrypto.a $${INSTALLDIR}/lib/
        cp -P $${INSTALLDIR}/staging/usr/lib/libssl.a $${INSTALLDIR}/lib/
        cp -r $${INSTALLDIR}/staging/usr/include/* $${INSTALLDIR}/include/
        rm -rf $${INSTALLDIR}/staging
    """,
    set_file_prefix_map = True,
    targets = [
        "build_libs",
        "install_dev",
    ],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "gen_static_dir",
    srcs = [":openssl_static"],
    output_group = "gen_dir",
    visibility = ["//visibility:public"],
)
