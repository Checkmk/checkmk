load("@@//bazel/rules:dependency_info.bzl", "dependency_info")
load("@rules_foreign_cc//foreign_cc:defs.bzl", "configure_make")

dependency_info(
    name = "dependency_info",
    package_name = "rrdtool",
    cpe_format_str = "cpe:2.3:a:rrdtool_project:rrdtool:%s:*:*:*:*:*:*:*",
    license_kind = "@package_metadata//licenses/spdx:GPL-2.0-only",
    license_text = "COPYRIGHT",
    purl_namespace = None,
    purl_type = "generic",
    version = module_version(),
)

MAKE_PARALLEL = "-j4"

filegroup(
    name = "all_srcs",
    srcs = glob(
        ["**/*"],
        exclude = ["bazel-*"],
    ),
    package_metadata = [":dependency_info"],
)

configure_make(
    name = "rrdtool",
    args = ["%s" % MAKE_PARALLEL],
    # Intentionally no @perl-modules dependency.  rrdtool's Perl bindings (RRDs,
    # RRDp) compile against core Perl only (DynaLoader + ExtUtils::MakeMaker) and
    # link librrd -- they consume no CPAN module from perl-modules.  The build
    # produces RRDs.so/RRDs.pm/RRDp.pm into rrdtool's own lib/perl5 tree, which is
    # what ships.  perl-modules was only ever an *install destination*: the old
    # --with-perl-options 'LIB=$(execpath ...:perl-modules)/...' pointed RRDs into
    # the perl-modules output tree, but commit 6c4631bd19d ("Update foreign_cc to
    # 0.11.1") repointed LIB= to $EXT_BUILD_DEPS (see --with-perl-options below).
    # The perl-modules.tar build_data had been staged but unused ever since, so
    # dropping it changes no functionality.  The bindings currently build against
    # the host Perl; a hermetic Perl toolchain will be introduced later, at which
    # point they should build against that instead.
    configure_in_place = True,
    configure_options = [
        "--verbose",
        "--disable-ruby",
        "--disable-libwrap",
        "--enable-perl-site-install",
        "--disable-tcl",
        "--disable-lua",
        "--disable-rrdcgi",
        "--disable-libdbi",
        "--disable-python",
        "--with-systemdsystemunitdir=no",
        "--with-perl-options='LIB=$${EXT_BUILD_DEPS}/lib/perl5/lib/perl5'",
        "CFLAGS='-Dredacted=\"redacted\"'",
        # Give up on pkg-config.  It's broken after updating foreign_cc
        # from 0.9.  We should switch to an entirely bazel-native solution
        # for this dependency soonish anyway.
        "PKGCONFIG='no'",
        "CPPFLAGS='" + " ".join([
            "-I/usr/include/blkid",
            "-I/usr/include/cairo",
            "-I/usr/include/freetype2",
            "-I/usr/include/fribidi",
            "-I/usr/include/glib-2.0",
            "-I/usr/include/harfbuzz",
            "-I/usr/include/libmount",
            "-I/usr/include/libpng16",
            "-I/usr/include/libxml2",
            "-I/usr/include/pango-1.0",
            "-I/usr/include/pixman-1",
            "-I/usr/include/uuid",
            "-I/usr/lib64/glib-2.0",
            "-I/usr/lib64/glib-2.0/include",
            "-I/usr/lib/x86_64-linux-gnu/glib-2.0/include",
        ]) + "'",
    ],
    copts = [
        "-I$BUILD_TMPDIR/include",
        "-Wno-stringop-overflow",
    ],
    env = {
        "CFLAGS": "'-Dredacted=\"redacted\"'",
        "RANLIB": "ranlib",
        "top_builddir": ".",
    },
    install_prefix = "$INSTALLDIR",
    lib_source = ":all_srcs",
    linkopts = [
        "-lcairo",
        "-lglib-2.0",
        "-lgobject-2.0",
        "-lpango-1.0",
        "-lpangocairo-1.0",
        "-lpng",
    ],
    out_data_dirs = [
        "lib/perl5/lib/perl5/",
    ],
    out_headers_only = True,
    postfix_script = """
        # The install step doesn't put the perl bindings where we
        # expect them.  So let's copy them here.
        LPLP="lib/perl5/lib/perl5"
        cp -R $${INSTALLDIR}$${EXT_BUILD_DEPS}/$$LPLP/* $${INSTALLDIR}/$$LPLP
        # remove unnecessary folders: since bazel 8, we also need to remove "root" under alma9
        rm -rf $${INSTALLDIR}/{home,usr,root}
    """,
    targets = [
        "-C po all",
        "-C src all",
        "-C tests all",
        "-C etc all",
        # Explicitly require perl bindings to make sure
        # we fail if they are not built.
        "-C bindings perl-piped",
        "-C bindings perl-shared",
        # DESTDIR for Perl, since the prefix is not honored
        "DESTDIR=$INSTALLDIR -C bindings install",
    ],
    visibility = ["//visibility:public"],
)

filegroup(
    name = "perl_bindings_gen_dir",
    srcs = [":rrdtool"],
    output_group = "gen_dir",
    visibility = ["//visibility:public"],
)
