"""python extension linter aspect for aspect_rules_lint framework"""

load("@aspect_rules_lint//lint:defs.bzl", "filter_srcs", "output_files")

_MNEMONIC = "AspectRulesLintPythonExtension"

def _python_extension_aspect_impl(target, ctx):
    if not hasattr(ctx.rule.attr, "srcs"):
        return []

    if hasattr(ctx.rule.attr, "tags") and "no-python-extension-checker" in ctx.rule.attr.tags:
        return []

    src_files = filter_srcs(ctx.rule)

    outputs, info = output_files(_MNEMONIC, target, ctx)

    if not src_files:
        # Using noop_lint_action(ctx, outputs) here results in an error since a conflicting
        # run_shell_0.sh file is generated by bazel/tools/lint_astrein.bzl
        ctx.actions.write(outputs.human.out, "")
        ctx.actions.write(outputs.machine.out, "")
        if outputs.human.exit_code:
            ctx.actions.write(outputs.human.exit_code, "0\n")
        if outputs.machine.exit_code:
            ctx.actions.write(outputs.machine.exit_code, "0\n")
        return [info]

    if outputs.human.exit_code and outputs.machine.exit_code:
        all_outputs = [
            outputs.human.out,
            outputs.machine.out,
            outputs.human.exit_code,
            outputs.machine.exit_code,
        ]
    else:
        all_outputs = [outputs.human.out, outputs.machine.out]

    python_extension_runfiles = ctx.attr._checker[DefaultInfo].default_runfiles.files
    ctx.actions.run(
        inputs = depset(src_files, transitive = [python_extension_runfiles]),
        outputs = all_outputs,
        executable = ctx.executable._checker,
        arguments = [
            outputs.human.out.path,
            outputs.machine.out.path,
            outputs.human.exit_code.path if outputs.human.exit_code else "",
            outputs.machine.exit_code.path if outputs.machine.exit_code else "",
        ] + [f.path for f in src_files],
        mnemonic = _MNEMONIC,
        progress_message = "Checking python extensions for %{label}",
    )

    return [info]

def lint_python_extension_aspect(binary):
    return aspect(
        implementation = _python_extension_aspect_impl,
        attr_aspects = ["deps"],
        attrs = {
            "_checker": attr.label(
                default = binary,
                executable = True,
                cfg = "exec",
            ),
            "_options": attr.label(default = "@aspect_rules_lint//lint:options"),
        },
    )
