load("@aspect_rules_py//py:defs.bzl", "py_library")
load("@cmk_requirements//:requirements.bzl", "requirement")

# Narrow target with the shared helpers used by both the legacy ``endpoints``
# package and the new-framework ``api_endpoints`` package. Extracting this
# lets ``api_endpoints`` depend on just these helpers without pulling in the
# full legacy ``endpoints`` library, breaking what would otherwise be a
# ``api_endpoints → endpoints → api_endpoints`` cycle.
py_library(
    name = "utils",
    srcs = ["utils.py"],
    imports = ["../../../.."],
    visibility = [
        "//cmk:__subpackages__",
        "//non-free/packages:__subpackages__",
        "//tests:__subpackages__",
    ],
    deps = [
        "//cmk/gui:customer",
        "//cmk/gui:exceptions",
        "//cmk/gui:groups",
        "//cmk/gui:http",
        "//cmk/gui/openapi:utils",
        "//cmk/gui/openapi/restful_objects",
        "//cmk/gui/openapi/restful_objects:type_defs",
        "//cmk/gui/watolib",
        "//cmk/gui/watolib:groups_io",
        "//cmk/utils",
        "//packages/cmk-ccc:site",
        "//packages/cmk-ccc:version",
        "//packages/cmk-livestatus-client:py_livestatus",
    ],
)

py_library(
    name = "endpoints",
    srcs = glob(
        include = ["**/*.py"],
        exclude = ["utils.py"],
    ),
    imports = ["../../../.."],
    visibility = [
        "//cmk:__subpackages__",
        "//non-free/packages:__subpackages__",
        "//tests:__subpackages__",
    ],
    deps = [
        ":utils",
        "//cmk/gui:autocompleters",
        "//cmk/gui:config",
        "//cmk/gui:customer",
        "//cmk/gui:default_permissions",
        "//cmk/gui:exceptions",
        "//cmk/gui:groups",
        "//cmk/gui:http",
        "//cmk/gui:i18n",
        "//cmk/gui:job_scheduler_client",
        "//cmk/gui:log",
        "//cmk/gui:logged_in",
        "//cmk/gui:permissions",
        "//cmk/gui:session",
        "//cmk/gui:site_config",
        "//cmk/gui:type_defs",
        "//cmk/gui/agent_registration",
        "//cmk/gui/background_job/job",
        "//cmk/gui/fields",
        "//cmk/gui/fields:base",
        "//cmk/gui/form_specs",
        "//cmk/gui/graphing",
        "//cmk/gui/livestatus_utils/commands",
        "//cmk/gui/openapi:utils",
        "//cmk/gui/openapi/api_endpoints",
        "//cmk/gui/openapi/framework",
        "//cmk/gui/openapi/framework:types",
        "//cmk/gui/openapi/restful_objects",
        "//cmk/gui/openapi/restful_objects:type_defs",
        "//cmk/gui/openapi/shared_endpoint_families",
        "//cmk/gui/openapi/spec:utils",
        "//cmk/gui/quick_setup",
        "//cmk/gui/rest_api_types:notifications",
        "//cmk/gui/userdb",
        "//cmk/gui/utils:agent",
        "//cmk/gui/utils:urls",
        "//cmk/gui/valuespec",
        "//cmk/gui/watolib",
        "//cmk/gui/watolib:config_infra",
        "//cmk/gui/watolib:groups_io",
        "//cmk/gui/watolib:password_store",
        "//cmk/gui/watolib:passwords",
        "//cmk/gui/watolib:registries",
        "//cmk/gui/watolib:timeperiods",
        "//cmk/product_usage",
        "//cmk/utils",
        "//packages/cmk-ccc:exceptions",
        "//packages/cmk-ccc:hostaddress",
        "//packages/cmk-ccc:site",
        "//packages/cmk-ccc:store",
        "//packages/cmk-ccc:user",
        "//packages/cmk-ccc:version",
        "//packages/cmk-crypto",
        "//packages/cmk-livestatus-client:py_livestatus",
        requirement("cryptography"),
        requirement("marshmallow"),
        requirement("marshmallow-oneofschema"),
        requirement("python-dateutil"),
        requirement("urllib3"),
        requirement("werkzeug"),
    ],
)
