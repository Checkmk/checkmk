# Remaining views root files that form the core orchestration layer.
# These depend on the subdirectory targets above.
filegroup(
    name = "gui_srcs",
    srcs = glob(
        include = ["**/*.py"],
        exclude = [
            "_openapi/**/*.py",
            "builtin_views.py",
            "command/**/*.py",
            "graph.py",
            "icon/**/*.py",
            "layout/**/*.py",
            "perfometer/**/*.py",
            "sorter/**/*.py",
            "store.py",
            "view_choices.py",
        ],
    ),
    visibility = ["//cmk/gui:__pkg__"],
)
