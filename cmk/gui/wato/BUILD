load("@aspect_rules_py//py:defs.bzl", "py_library")
load("@cmk_requirements//:requirements.bzl", "requirement")

# Leaf target exposing wato types/helpers that feature modules need (quick_setup,
# mkeventd, ldap_integration, oauth2_connections, backup, ...). This lets features
# depend on wato:base without creating a cycle with the rest of wato, which in turn
# depends on those features for registration. Includes __init__.py so features can
# use the clean `from cmk.gui.wato import X` public API.
py_library(
    name = "base",
    srcs = [
        "__init__.py",
        "_check_mk_configuration.py",
        "_check_plugin_selection.py",
        "_group_selection.py",
        "_http_proxy.py",
        "_levels.py",
        "_main_module_topics.py",
        "_permissions.py",
        "pages/_match_conditions.py",
        "pages/_password_store_valuespecs.py",
        "pages/_rule_conditions.py",
        "pages/_simple_modes.py",
        "pages/_tile_menu.py",
        "pages/global_settings.py",
        "pages/user_profile/main_menu.py",
        "pages/userdb_common.py",
        "piggyback_hub.py",
    ],
    imports = ["../../.."],
    visibility = [
        "//cmk:__subpackages__",
        "//tests:__subpackages__",
    ],
    deps = [
        "//cmk/gui:breadcrumb",
        "//cmk/gui:config",
        "//cmk/gui:customer",
        "//cmk/gui:default_name",
        "//cmk/gui:exceptions",
