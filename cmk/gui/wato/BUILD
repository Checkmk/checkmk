        "//cmk/gui:sites",
        "//cmk/gui:table",
        "//cmk/gui:theme",
        "//cmk/gui:type_defs",
        "//cmk/gui:user_connection_config_types",
        "//cmk/gui:view_utils",
        "//cmk/gui:weblib",
