load("@aspect_rules_py//py:defs.bzl", "py_library")

# Leaf target exposing wato types/helpers that feature modules need (quick_setup,
# mkeventd, ldap_integration, oauth2_connections, backup, ...). This lets features
# depend on wato:base without creating a cycle with the rest of wato, which in turn
# depends on those features for registration. Includes __init__.py so features can
# use the clean `from cmk.gui.wato import X` public API.
py_library(
    name = "base",
    srcs = [
        "__init__.py",
        "_check_mk_configuration.py",
        "_check_plugin_selection.py",
        "_group_selection.py",
        "_http_proxy.py",
        "_levels.py",
        "_main_module_topics.py",
        "_permissions.py",
        "pages/_match_conditions.py",
        "pages/_password_store_valuespecs.py",
        "pages/_rule_conditions.py",
        "pages/_simple_modes.py",
        "pages/_tile_menu.py",
        "pages/global_settings.py",
        "pages/user_profile/main_menu.py",
        "pages/userdb_common.py",
        "piggyback_hub.py",
    ],
    imports = ["../../.."],
    visibility = [
        "//cmk:__subpackages__",
        "//tests:__subpackages__",
    ],
    deps = [
        "//cmk/gui:breadcrumb",
        "//cmk/gui:config",
        "//cmk/gui:customer",
        "//cmk/gui:default_name",
        "//cmk/gui:exceptions",
        "//cmk/gui:forms",
        "//cmk/gui:global_config",
        "//cmk/gui:groups",
        "//cmk/gui:hooks",
        "//cmk/gui:http",
        "//cmk/gui:i18n",
        "//cmk/gui:legacy_plugins",
        "//cmk/gui:log",
        "//cmk/gui:logged_in",
        "//cmk/gui:main_menu",
        "//cmk/gui:main_menu_types",
        "//cmk/gui:page_menu",
        "//cmk/gui:pages",
        "//cmk/gui:permissions",
        "//cmk/gui:site_config",
        "//cmk/gui:sites",
        "//cmk/gui:table",
        "//cmk/gui:theme",
        "//cmk/gui:type_defs",
        "//cmk/gui:user_connection_config_types",
        "//cmk/gui:view_utils",
        "//cmk/gui:weblib",
        "//cmk/gui/background_job/job",
        "//cmk/gui/form_specs",
        "//cmk/gui/htmllib:generator",
        "//cmk/gui/htmllib:html",
        "//cmk/gui/search",
        "//cmk/gui/userdb",
        "//cmk/gui/utils:compatibility",
        "//cmk/gui/utils:csrf_token",
        "//cmk/gui/utils:escaping",
        "//cmk/gui/utils:flashed_messages",
        "//cmk/gui/utils:html",
        "//cmk/gui/utils:roles",
        "//cmk/gui/utils:transaction_manager",
        "//cmk/gui/utils:urls",
        "//cmk/gui/valuespec",
        "//cmk/gui/views:icon",
        "//cmk/gui/visuals",
        "//cmk/gui/watolib",
        "//cmk/gui/watolib:config_infra",
        "//cmk/gui/watolib:groups_io",
        "//cmk/utils",
        "//packages/cmk-ccc:exceptions",
        "//packages/cmk-ccc:site",
        "//packages/cmk-shared-typing:cmk_shared_typing_py",
    ],
)

# Temporary: wato files that still belong to the monolithic //cmk/gui target.
