#!/bin/bash

# Alias: TCP port number for Apache
# Menu: Web GUI
# Description:
#  Configure the TCP port used for the Apache webserver
#  process of this site.
#
#  After changing this variable, the man Apache webserver
#  must be restarted.

case "$1" in
    choices)
        echo "@{APACHE_NETWORK_PORT}"
        ;;
esac
