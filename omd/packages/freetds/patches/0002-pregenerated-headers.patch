+/**
+ * Return the number of bytes needed by specified type.
+ */
+int
+tds_get_size_by_type(TDS_SERVER_TYPE servertype)
+{
+	switch (servertype) {
+	case SYBVOID:
+		return 0;
+	case SYBBIT:
+	case SYBBITN:
+	case SYBINT1:
+	case SYBSINT1:
+	case SYBUINT1:
+		return 1;
+	case SYBINT2:
+	case SYBUINT2:
+		return 2;
+	case SYBMSDATE:
+		return 3;
+	case SYBDATE:
+	case SYBDATEN:
+	case SYBDATETIME4:
+	case SYBINT4:
+	case SYBMONEY4:
+	case SYBREAL:
+	case SYBTIME:
+	case SYBTIMEN:
+	case SYBUINT4:
+		return 4;
+	case SYB5BIGDATETIME:
+	case SYB5BIGTIME:
+	case SYB5INT8:
+	case SYBDATETIME:
+	case SYBFLT8:
+	case SYBINT8:
+	case SYBINTERVAL:
+	case SYBMONEY:
+	case SYBUINT8:
+		return 8;
+	case SYBUNIQUE:
+		return 16;
+	default:
+		return 0;
+	}
+}
