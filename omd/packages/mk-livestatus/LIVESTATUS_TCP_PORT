#!/bin/bash

# Alias: TCP port number for MK Livestatus
# Menu: Distributed Monitoring
# Description:
#  If Livestatus is configured to listen on a TCP port, you
#  can configure that port here.

case "$1" in
    choices)
        echo "[0-9]{1,5}"
        ;;
    depends)
        [ "$CONFIG_CORE" != none -a "$CONFIG_LIVESTATUS_TCP" = on ]
        ;;
esac
