{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "title": "dialog",
  "properties": {
    "title": { "type": "string" },
    "message": { "type": "string" },
    "main_button": { "$ref": "#/$defs/main_button" },
    "optional_button": { "$ref": "#/$defs/optional_button" }
  },
  "required": ["message"],
  "$defs": {
    "main_button": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "action": { "$ref": "#/$defs/dialog_action" }
      },
      "required": ["title", "action"]
    },
    "optional_button": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "action": { "$ref": "#/$defs/dialog_action" },
        "dismissal": { "$ref": "#/$defs/dismissal" }
      },
      "required": ["title"]
    },
    "dismissal": {
      "type": "object",
      "properties": {
        "key": {
          "enum": [
            "notification_fallback",
            "immediate_slideout_change",
            "changes-info",
            "agent_slideout"
          ]
        }
      },
      "required": ["key"]
    },
    "dialog_action": {
      "oneOf": [{ "$ref": "#/$defs/redirect_action" }]
    },
    "redirect_action": {
      "type": "object",
      "properties": {
        "type": { "const": "redirect" },
        "url": { "type": "string" }
      },
      "required": ["type", "url"]
    }
  }
}
