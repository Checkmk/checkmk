{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GlobalTimePickerProps",
  "type": "object",
  "properties": {
    "custom_time_ranges": {
      "type": "array",
      "items": { "$ref": "#/$defs/custom_graph_time_range" }
    },
    "default_time_range": { "type": "number" },
    "server_time_zone": { "type": "string" }
  },
  "required": ["custom_time_ranges", "default_time_range", "server_time_zone"],
  "$defs": {
    "custom_graph_time_range": {
      "title": "CustomGraphTimeRange",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "total_seconds": { "type": "number" }
      },
      "required": ["title", "total_seconds"]
    }
  }
}
