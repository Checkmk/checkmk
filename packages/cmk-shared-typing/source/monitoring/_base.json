{
  "$schema": "https://json-schema.org/draft/2019-09/schema",
  "type": "object",
  "title": "Monitoring - Base Structure",
  "properties": {
    "poll_interval_ms": {
      "type": "number",
      "default": 30000
    },
    "actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/monitoring_action" },
      "default": []
    }
  },
  "$defs": {
    "monitoring_action": {
      "type": "object",
      "properties": {
        "ident": { "type": "string" },
        "title": { "type": "string" }
      },
      "required": ["ident", "title"]
    }
  }
}
