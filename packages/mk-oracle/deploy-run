#!/bin/bash
# deploy-run: Build mk-oracle as a fully static musl binary, deploy to a remote host, and run it.
#
# Usage: ./deploy-run [-o oracle-home] <config-file> <remote-host> [extra-args...]
#
#   -o path         Optional: sets ORACLE_HOME=<path> in the remote environment
#   -l path         Optional: sets MK_LIBDIR=<path> in the remote environment
#   config-file     Local file copied to the remote host (passed as -c <remote-path>)
#   remote-host     SSH destination, e.g. user@192.168.111.111
#   extra-args      Any additional arguments forwarded verbatim to mk-oracle on the remote

# Examples:
# With typical  ORACLE_HOME:
# ./deploy-run -o /opt/oracle23/u01/app/oracle/dbhome1 ./tests/files/test-local.yml user@machine-with-oracle
# other commands
# ./deploy-run -l /tmp/plugins ./tests/files/test-local.yml user@machine-with-oracle --detect-sids
# ./deploy-run ./tests/files/test-local.yml user@machine-with-oracle --version
# using file with some variables:
# DB_PORT=1521 DB_SID=SID23 DB_PASSWORD=$CI_ORA_TEST_PASSWORD ./deploy-run -o /opt/oracle23/u01/app/oracle/dbhome1 ./tests/files/test-template.yml rocky@ora-rocktest.dev.checkmk.net
# DB_PORT=1522 DB_SID=SID19 DB_PASSWORD=$CI_ORA_TEST_PASSWORD ./deploy-run -o /opt/oracle23/u01/app/oracle/dbhome1 ./tests/files/test-template.yml rocky@ora-rocktest.dev.checkmk.net

set -euo pipefail

GNU_TARGET="x86_64-unknown-linux-gnu"
BINARY_NAME="mk-oracle"
REMOTE_DEPLOY_DIR="/tmp/${USER}-deploy-run/${BINARY_NAME}-check"

# ---------------------------------------------------------------------------
# Argument parsing
# ---------------------------------------------------------------------------
ORACLE_HOME=""
MK_LIBDIR=""
while getopts ":o:l:" opt; do
    case "${opt}" in
        o) ORACLE_HOME="${OPTARG}" ;;
        l) MK_LIBDIR="${OPTARG}" ;;
        :)
            echo "Error: -${OPTARG} requires a path argument." >&2
            exit 1
            ;;
        ?)
            echo "Error: unknown option -${OPTARG}." >&2
            exit 1
            ;;
    esac
done
shift $((OPTIND - 1))

if [[ $# -lt 2 ]]; then
    echo "Usage: $0 [-o oracle-home] [-l mk-libdir] <config-file> <remote-host> [extra-args...]" >&2
    exit 1
fi

CONFIG_FILE="$1"
REMOTE_HOST="$2"
shift 2
EXTRA_ARGS=("$@")

if [[ ! -f "${CONFIG_FILE}" ]]; then
    echo "Error: config file '${CONFIG_FILE}' not found." >&2
    exit 1
fi

CONFIG_BASENAME="$(basename "${CONFIG_FILE}")"
TMP_CONFIG="$(mktemp --suffix="-${CONFIG_BASENAME}")"
trap 'rm -f "${TMP_CONFIG}"' EXIT

# Resolve paths relative to this script, not the caller's cwd
SCRIPT_DIR="$(cd -- "${BASH_SOURCE%/*}" && pwd)"
WORKSPACE_ROOT="$(git rev-parse --show-toplevel)"
# may be changed in the future
TARGET_DIR="."
BINARY_PATH="${WORKSPACE_ROOT}/${TARGET_DIR}/target/${GNU_TARGET}/release/${BINARY_NAME}"

SSH_OPTS=(-o ConnectTimeout=10 -o BatchMode=yes)

# ---------------------------------------------------------------------------
# Step 1: ensure cargo-zigbuild is available
# ---------------------------------------------------------------------------
if ! command -v cargo-zigbuild &>/dev/null; then
    echo "==> [1/5] Installing cargo-zigbuild..."
    cargo install cargo-zigbuild
else
    echo "==> [1/5] cargo-zigbuild already installed, skipping."
fi

# ---------------------------------------------------------------------------
# Step 2: build binary targeting glibc 2.17 for maximum compatibility
# ---------------------------------------------------------------------------
echo "==> [2/5] Building binary (glibc 2.17)..."
cd "${SCRIPT_DIR}"
cargo zigbuild --release --target x86_64-unknown-linux-gnu.2.17

if [[ ! -f "${BINARY_PATH}" ]]; then
    echo "Error: expected binary not found at '${BINARY_PATH}'." >&2
    exit 1
fi
echo "    Binary: ${BINARY_PATH}"

# ---------------------------------------------------------------------------
# Step 3: copy binary to remote
# ---------------------------------------------------------------------------
echo "==> [3/5] Copying binary to ${REMOTE_HOST}:${REMOTE_DEPLOY_DIR}/..."
ssh "${SSH_OPTS[@]}" "${REMOTE_HOST}" "mkdir -p ${REMOTE_DEPLOY_DIR}"
scp "${SSH_OPTS[@]}" "${BINARY_PATH}" "${REMOTE_HOST}:${REMOTE_DEPLOY_DIR}/${BINARY_NAME}"

# ---------------------------------------------------------------------------
# Step 4: expand shell variables in config, copy expanded version to remote
# ---------------------------------------------------------------------------
echo "==> [4/5] Expanding variables in '${CONFIG_FILE}' and copying to ${REMOTE_HOST}:${REMOTE_DEPLOY_DIR}/..."
# Collect only variables that are defined in the current environment so that
# undefined references are left as-is rather than replaced with empty strings.
# grep may return 1 (no matches) — that is not an error here.
raw_refs=$(grep -oE '\$\{[A-Za-z_][A-Za-z0-9_]*\}|\$[A-Za-z_][A-Za-z0-9_]*' "${CONFIG_FILE}" || true)
defined_vars=""
if [[ -n "${raw_refs}" ]]; then
    defined_vars=$(printf '%s\n' "${raw_refs}" |
        grep -oE '[A-Za-z_][A-Za-z0-9_]*' | sort -u |
        while IFS= read -r v; do if [[ -v "$v" ]]; then printf '${%s}' "$v"; fi; done)
fi
[[ -n "${defined_vars}" ]] && echo "    Expanding: ${defined_vars}"
envsubst "${defined_vars}" <"${CONFIG_FILE}" >"${TMP_CONFIG}"
scp "${SSH_OPTS[@]}" "${TMP_CONFIG}" "${REMOTE_HOST}:${REMOTE_DEPLOY_DIR}/${CONFIG_BASENAME}"

# ---------------------------------------------------------------------------
# Step 5: run binary on remote
# ---------------------------------------------------------------------------
REMOTE_BINARY="${REMOTE_DEPLOY_DIR}/${BINARY_NAME}"
REMOTE_CONFIG="${REMOTE_DEPLOY_DIR}/${CONFIG_BASENAME}"

ENV_PREFIX=""
[[ -n "${ORACLE_HOME}" ]] && ENV_PREFIX+="ORACLE_HOME=${ORACLE_HOME} "
[[ -n "${MK_LIBDIR}" ]] && ENV_PREFIX+="MK_LIBDIR=${MK_LIBDIR} "

echo "==> [5/5] Running on ${REMOTE_HOST}: ${ENV_PREFIX}${BINARY_NAME} -c ${REMOTE_CONFIG} ${EXTRA_ARGS[*]+"${EXTRA_ARGS[*]}"}"
echo "--- output ---"
ssh "${SSH_OPTS[@]}" "${REMOTE_HOST}" "chmod +x ${REMOTE_BINARY} && ${ENV_PREFIX}${REMOTE_BINARY} -c ${REMOTE_CONFIG}${EXTRA_ARGS:+ ${EXTRA_ARGS[*]}}"
