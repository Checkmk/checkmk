set -e

SITE=${SITE:-$(until [ "${PWD}" = / ]; do if [ -e .site ]; then
    cat .site
    break
else cd ..; fi; done)}
SITE=${SITE:-$(omd sites --bare | head -n 1)}
ROOT=/omd/sites/$SITE
test -d "${ROOT}" || exit 1

VERSION=$(make --quiet --directory="$(bazel info workspace)" print-VERSION)
if test -z ${VALGRIND+x} && command -v valgrind >/dev/null; then
    VALGRIND="$(which valgrind) --quiet --num-callers=30 --error-exitcode=42"
fi
bazel test --cmk_version="${VERSION}" ${VALGRIND:+--run_under="${VALGRIND}"} //packages/neb:all
