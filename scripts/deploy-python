set -e

SITE=${SITE:-$(until [ "${PWD}" = / ]; do if [ -e .site ]; then
    cat .site
    break
else cd ..; fi; done)}
SITE=${SITE:-$(omd sites --bare | head -n 1)}
ROOT=/omd/sites/$SITE
test -d "${ROOT}" || exit 1

VERSION="$(realpath "${ROOT}/version")"
EDITION="${VERSION##*.}"

exec bazel run //:deploy-python --cmk_edition="${EDITION}" -- "${ROOT}"
